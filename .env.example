# ─── LLM Provider ────────────────────────────────────────────────
# Choose one: claude | gemini | ollama
LLM_PROVIDER=gemini

# ─── Anthropic Claude ────────────────────────────────────────────
CLAUDE_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514        # optional, this is the default

# ─── Google Gemini ───────────────────────────────────────────────
GEMINI_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-1.5-flash                # optional, this is the default

# ─── Local Ollama ────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434        # optional, this is the default
OLLAMA_MODEL=llama3.2                        # optional, this is the default

# ─── TTS Provider ────────────────────────────────────────────────
# Choose one: piper | openai | pyttsx3
TTS_PROVIDER=piper

# ── Piper (primary, fully local) ─────────────────────────────────
# The bundled piper.exe and model are already in models/piper/.
# You do NOT need to change anything below if you kept that folder structure.
#
# PIPER_EXE        — path to piper.exe (absolute, or relative to project root)
# PIPER_MODEL_PATH — path to the .onnx voice model
# PIPER_CONFIG_PATH— path to the .onnx.json config (auto-detected if left blank)
# PIPER_SAMPLE_RATE— must match the model; lessac-medium = 22050
#
# Leave these commented out to use the auto-detected bundled paths:
# PIPER_EXE=models/piper/piper.exe
# PIPER_MODEL_PATH=models/piper/en_US-lessac-medium.onnx
# PIPER_CONFIG_PATH=models/piper/en_US-lessac-medium.onnx.json
PIPER_SAMPLE_RATE=22050

# ── OpenAI TTS (optional alternative) ────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_SPEED=1.0
OPENAI_TTS_RATE=24000
